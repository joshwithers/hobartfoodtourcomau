---
interface Props {
  title?: string
  description?: string
  primaryHref?: string
  primaryLabel?: string
  secondaryHref?: string
  secondaryLabel?: string
}
const {
  title = 'Pull up a stool. The first bite’s on us.',
  description = 'The Hobart food tour sells out 2 to 3 weeks ahead in summer. Lock yours in — or get a quote for a private group built around your party.',
  primaryHref = '/tours/hobart-food-tour/',
  primaryLabel = 'Book the food tour',
  secondaryHref = '/contact/?tour=private-charter',
  secondaryLabel = 'Enquire about a private group',
} = Astro.props
---

<section class="closing-cta surface-dark">
  <div class="container cta-grid">
    <div class="cta-art" aria-hidden="true">
      <svg viewBox="0 0 480 240" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 200 Q120 60 240 160 T480 100" stroke="var(--color-accent)" stroke-width="80" stroke-linecap="round" fill="none" opacity="0.85" />
        <path d="M0 200 Q120 60 240 160 T480 100" stroke="rgba(255,254,251,0.06)" stroke-width="100" stroke-linecap="round" fill="none" />
      </svg>
    </div>
    <div class="cta-text">
      <span class="kicker cta-kicker">Ready when you are</span>
      <h2 class="cta-headline">{title}</h2>
      <p class="cta-body">{description}</p>
      <div class="cta-actions">
        <a href={primaryHref} class="btn btn-primary btn-lg">{primaryLabel}</a>
        <a href={secondaryHref} class="btn cta-secondary btn-lg">{secondaryLabel}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .closing-cta {
    padding-block: clamp(56px, 6vw, 96px);
    background: var(--color-ink);
    overflow: hidden;
    position: relative;
  }
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 56px;
    align-items: center;
    position: relative;
  }
  .cta-art {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    opacity: 0.92;
  }
  .cta-art svg { width: 100%; height: 100%; }

  .cta-kicker { color: var(--color-accent); }
  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 2.5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-canvas);
    font-weight: 700;
    margin-block: 12px 18px;
  }
  .cta-body {
    color: rgba(255, 254, 251, 0.78);
    font-size: 1.05rem;
    line-height: 1.55;
    max-width: 50ch;
    margin-bottom: 28px;
  }
  .cta-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .cta-secondary {
    background: transparent;
    color: var(--color-canvas);
    border: 1px solid rgba(255,254,251,0.3);
  }
  .cta-secondary:hover { background: rgba(255,254,251,0.08); border-color: var(--color-canvas); }

  @media (max-width: 880px) {
    .cta-grid { grid-template-columns: 1fr; gap: 32px; }
    .cta-art { display: none; }
  }
</style>
