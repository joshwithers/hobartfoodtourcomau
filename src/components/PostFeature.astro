---
type FeatureKey =
  | 'medals'
  | 'city-map'
  | 'winter'
  | 'still'
  | 'coach'
  | 'flowers'
  | 'water'
  | 'two-cities'
  | 'boots'
  | 'checklist'

interface Props {
  feature: FeatureKey
  swatch?: [string, string, string]
  class?: string
}

const {
  feature,
  swatch = ['#3a2418', '#a85a2c', '#e6c79a'],
  class: className,
} = Astro.props

const [a, b, c] = swatch
---

<div class={`post-feature ${className ?? ''}`} aria-hidden="true">
  <svg viewBox="0 0 800 360" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
    <defs>
      <linearGradient id={`pf-bg-${feature}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color={a} />
        <stop offset="100%" stop-color={b} />
      </linearGradient>
      <pattern id={`pf-dots-${feature}`} width="14" height="14" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1.1" fill="rgba(255,254,251,0.06)" />
      </pattern>
    </defs>
    <rect width="800" height="360" fill={`url(#pf-bg-${feature})`} />
    <rect width="800" height="360" fill={`url(#pf-dots-${feature})`} />

    {feature === 'medals' && (
      <g>
        {/* trophy on a plinth */}
        <rect x="320" y="240" width="160" height="40" rx="3" fill={a} />
        <rect x="340" y="220" width="120" height="20" fill={a} opacity="0.85" />
        <path d="M340 220 Q340 110 460 110 Q580 110 580 220 Z" fill={c} opacity="0.92" />
        <path d="M340 220 Q340 110 460 110 Q580 110 580 220 Z" fill="#ff4f00" opacity="0.55" />
        <ellipse cx="400" cy="170" rx="30" ry="40" fill={c} opacity="0.8" />
        <text x="400" y="180" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="34" fill={a}>1</text>
        {/* medals */}
        <g>
          <circle cx="180" cy="200" r="40" fill="#e6c79a" />
          <circle cx="180" cy="200" r="32" fill="#ff4f00" />
          <text x="180" y="208" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="20" fill={a}>AIBA</text>
          <path d="M160 240 L150 290 L180 280 L210 290 L200 240 Z" fill="#ff4f00" opacity="0.85" />
        </g>
        <g>
          <circle cx="620" cy="220" r="34" fill="#e6c79a" opacity="0.85" />
          <circle cx="620" cy="220" r="26" fill="#ff4f00" opacity="0.85" />
          <text x="620" y="227" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="14" fill={a}>GOLD</text>
        </g>
        {/* hops */}
        <g stroke={c} stroke-width="2" fill="none" opacity="0.6">
          <path d="M40 60 Q70 90 60 130 T80 200" />
          <path d="M740 50 Q720 90 730 130 T720 200" />
        </g>
      </g>
    )}

    {feature === 'city-map' && (
      <g>
        {/* lake */}
        <path d="M100 140 Q300 90 500 150 T720 130 L720 220 Q500 240 320 210 T100 230 Z" fill={c} opacity="0.7" />
        {/* roads */}
        <g stroke={c} stroke-width="3" fill="none" stroke-linecap="round" opacity="0.85">
          <line x1="0" y1="120" x2="800" y2="60" />
          <line x1="0" y1="280" x2="800" y2="240" />
          <line x1="200" y1="0" x2="280" y2="360" />
          <line x1="500" y1="0" x2="540" y2="360" />
        </g>
        {/* landmark pins */}
        <g>
          <circle cx="220" cy="100" r="8" fill="#ff4f00" />
          <text x="232" y="105" font-family="var(--font-display)" font-weight="700" font-size="11" fill={c}>BRADDON</text>
          <circle cx="380" cy="240" r="8" fill="#ff4f00" />
          <text x="392" y="245" font-family="var(--font-display)" font-weight="700" font-size="11" fill={c}>FYSHWICK</text>
          <circle cx="560" cy="200" r="8" fill="#ff4f00" />
          <text x="572" y="205" font-family="var(--font-display)" font-weight="700" font-size="11" fill={c}>MITCHELL</text>
          <circle cx="650" cy="80" r="8" fill="#ff4f00" />
          <text x="662" y="85" font-family="var(--font-display)" font-weight="700" font-size="11" fill={c}>PIALLIGO</text>
        </g>
        {/* compass */}
        <g transform="translate(80, 60)">
          <circle r="22" fill="none" stroke={c} stroke-width="1.5" opacity="0.7" />
          <polygon points="0,-22 4,0 0,16 -4,0" fill="#ff4f00" />
          <text y="-26" text-anchor="middle" font-family="var(--font-display)" font-weight="700" font-size="9" fill={c}>N</text>
        </g>
      </g>
    )}

    {feature === 'winter' && (
      <g>
        {/* moon */}
        <circle cx="120" cy="80" r="36" fill="#fcd28b" opacity="0.85" />
        <circle cx="135" cy="72" r="32" fill={a} opacity="0.5" />
        {/* mountains */}
        <polygon points="0,260 200,140 380,260" fill={a} />
        <polygon points="280,260 480,120 680,260" fill={a} opacity="0.92" />
        <polygon points="560,260 760,160 800,260" fill={a} opacity="0.85" />
        {/* snow caps */}
        <polygon points="180,150 200,140 220,150 200,170" fill={c} opacity="0.92" />
        <polygon points="460,130 480,120 500,130 480,160" fill={c} opacity="0.92" />
        {/* lit pub windows */}
        <rect x="320" y="240" width="160" height="60" fill={a} />
        <rect x="335" y="252" width="22" height="30" fill="#fcd28b" opacity="0.8" />
        <rect x="370" y="252" width="22" height="30" fill="#fcd28b" opacity="0.8" />
        <rect x="405" y="252" width="22" height="30" fill="#fcd28b" opacity="0.8" />
        <rect x="440" y="252" width="22" height="30" fill="#fcd28b" opacity="0.8" />
        {/* falling snow */}
        <g fill={c} opacity="0.85">
          <circle cx="60" cy="40" r="2" />
          <circle cx="180" cy="180" r="2" />
          <circle cx="240" cy="60" r="2" />
          <circle cx="320" cy="100" r="2" />
          <circle cx="450" cy="40" r="2" />
          <circle cx="540" cy="180" r="2" />
          <circle cx="640" cy="60" r="2" />
          <circle cx="720" cy="220" r="2" />
        </g>
      </g>
    )}

    {feature === 'still' && (
      <g>
        {/* ground */}
        <rect x="0" y="280" width="800" height="80" fill={a} />
        {/* big pot still */}
        <ellipse cx="280" cy="240" rx="120" ry="80" fill={c} opacity="0.92" />
        <rect x="240" y="100" width="80" height="140" fill={c} opacity="0.92" />
        <rect x="220" y="80" width="120" height="24" fill="#ff4f00" />
        {/* condenser pipe */}
        <path d="M340 130 Q420 60 540 130" stroke="#ff4f00" stroke-width="14" fill="none" />
        <path d="M340 130 Q420 60 540 130" stroke={c} stroke-width="6" fill="none" opacity="0.4" />
        {/* second still */}
        <ellipse cx="600" cy="260" rx="80" ry="50" fill={c} opacity="0.92" />
        <rect x="570" y="170" width="60" height="100" fill={c} opacity="0.92" />
        <rect x="555" y="155" width="90" height="20" fill="#ff4f00" opacity="0.8" />
        {/* tasting glass */}
        <g transform="translate(120, 200)">
          <path d="M-14 0 L14 0 L10 28 L-10 28 Z" fill={c} opacity="0.7" />
          <path d="M-12 4 L12 4 L8 14 L-8 14 Z" fill="#ff4f00" opacity="0.7" />
          <rect x="-2" y="28" width="4" height="20" fill={c} opacity="0.7" />
          <ellipse cx="0" cy="50" rx="14" ry="3" fill={c} opacity="0.7" />
        </g>
      </g>
    )}

    {feature === 'coach' && (
      <g>
        {/* sky stripes */}
        <rect x="0" y="60" width="800" height="6" fill={c} opacity="0.4" />
        <rect x="0" y="100" width="800" height="3" fill={c} opacity="0.3" />
        {/* road */}
        <rect x="0" y="270" width="800" height="90" fill={a} />
        <g stroke={c} stroke-width="3" stroke-dasharray="20 20" opacity="0.7">
          <line x1="0" y1="320" x2="800" y2="320" />
        </g>
        {/* coach */}
        <g>
          <rect x="180" y="160" width="440" height="120" rx="12" fill={c} />
          <rect x="200" y="170" width="50" height="30" rx="4" fill="#ff4f00" />
          <rect x="270" y="180" width="60" height="40" fill="#fcd28b" opacity="0.7" />
          <rect x="345" y="180" width="60" height="40" fill="#fcd28b" opacity="0.7" />
          <rect x="420" y="180" width="60" height="40" fill="#fcd28b" opacity="0.7" />
          <rect x="495" y="180" width="60" height="40" fill="#fcd28b" opacity="0.7" />
          <text x="400" y="262" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="18" fill={a} letter-spacing="2">DAVES · CANBERRA</text>
          {/* wheels */}
          <circle cx="240" cy="290" r="22" fill={a} stroke={c} stroke-width="3" />
          <circle cx="560" cy="290" r="22" fill={a} stroke={c} stroke-width="3" />
        </g>
        {/* clouds */}
        <ellipse cx="80" cy="80" rx="40" ry="14" fill={c} opacity="0.5" />
        <ellipse cx="700" cy="60" rx="46" ry="12" fill={c} opacity="0.5" />
      </g>
    )}

    {feature === 'flowers' && (
      <g>
        {/* night sky stars */}
        <g fill={c} opacity="0.6">
          <circle cx="60" cy="50" r="1.5" />
          <circle cx="160" cy="80" r="2" />
          <circle cx="320" cy="40" r="1.8" />
          <circle cx="500" cy="70" r="2" />
          <circle cx="680" cy="50" r="1.5" />
        </g>
        {/* string lights */}
        <path d="M0 80 Q200 130 400 90 T800 110" stroke={c} stroke-width="1.5" fill="none" opacity="0.6" />
        <g fill="#fcd28b">
          <circle cx="100" cy="105" r="3" />
          <circle cx="200" cy="115" r="3" />
          <circle cx="300" cy="100" r="3" />
          <circle cx="400" cy="90" r="3" />
          <circle cx="500" cy="95" r="3" />
          <circle cx="600" cy="105" r="3" />
          <circle cx="700" cy="105" r="3" />
        </g>
        {/* tulip rows */}
        <g>
          {[...Array(7)].map((_, r) => (
            <g>
              {[...Array(12)].map((__, i) => {
                const x = 40 + i * 64
                const y = 220 + r * 18
                const colors = ['#ff4f00', '#fcd28b', '#e84600', c, '#ff7f00']
                const color = colors[(i + r) % colors.length]
                return (
                  <g>
                    <ellipse cx={x} cy={y} rx="6" ry="9" fill={color} opacity={0.8 - r * 0.05} />
                    <line x1={x} y1={y + 6} x2={x} y2={y + 26} stroke={c} stroke-width="1.2" opacity="0.5" />
                  </g>
                )
              })}
            </g>
          ))}
        </g>
      </g>
    )}

    {feature === 'water' && (
      <g>
        {/* faucet */}
        <rect x="340" y="60" width="120" height="20" fill={c} opacity="0.9" />
        <rect x="430" y="80" width="20" height="60" fill={c} opacity="0.9" />
        <rect x="380" y="20" width="40" height="50" fill={c} opacity="0.9" />
        <circle cx="400" cy="20" r="14" fill="#ff4f00" />
        {/* water stream */}
        <path d="M440 140 Q445 200 440 260" stroke={c} stroke-width="6" fill="none" opacity="0.85" />
        {/* droplets */}
        <g fill={c} opacity="0.92">
          <path d="M440 280 Q435 300 440 310 Q445 300 440 280 Z" />
          <path d="M380 240 Q377 252 380 258 Q383 252 380 240 Z" />
          <path d="M500 250 Q497 262 500 268 Q503 262 500 250 Z" />
        </g>
        {/* glass beneath */}
        <path d="M380 280 L500 280 L490 340 L390 340 Z" fill={c} opacity="0.55" />
        <rect x="380" y="276" width="120" height="6" fill={c} />
        {/* mineral chips floating around */}
        <g>
          <text x="120" y="180" font-family="var(--font-display)" font-weight="800" font-size="22" fill={c} opacity="0.7">Ca²⁺</text>
          <text x="180" y="260" font-family="var(--font-display)" font-weight="800" font-size="20" fill={c} opacity="0.65">Mg²⁺</text>
          <text x="640" y="180" font-family="var(--font-display)" font-weight="800" font-size="22" fill={c} opacity="0.7">SO₄²⁻</text>
          <text x="600" y="260" font-family="var(--font-display)" font-weight="800" font-size="20" fill={c} opacity="0.65">Cl⁻</text>
        </g>
      </g>
    )}

    {feature === 'two-cities' && (
      <g>
        {/* divider */}
        <line x1="400" y1="40" x2="400" y2="320" stroke={c} stroke-width="2" stroke-dasharray="6 6" opacity="0.6" />
        {/* SYDNEY side */}
        <g>
          <text x="200" y="80" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="22" fill={c} letter-spacing="3">SYDNEY</text>
          {/* opera house shells */}
          <g fill={c}>
            <path d="M120 240 Q160 180 220 240 Z" />
            <path d="M160 250 Q200 190 260 250 Z" opacity="0.85" />
            <path d="M200 260 Q240 200 300 260 Z" opacity="0.7" />
          </g>
          {/* harbour */}
          <rect x="40" y="270" width="320" height="60" fill={c} opacity="0.5" />
          {/* bridge */}
          <path d="M60 270 Q160 200 260 270" stroke={c} stroke-width="3" fill="none" />
        </g>
        {/* CANBERRA side */}
        <g>
          <text x="600" y="80" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="22" fill={c} letter-spacing="3">CANBERRA</text>
          {/* parliament flagpole */}
          <line x1="600" y1="100" x2="600" y2="240" stroke={c} stroke-width="4" />
          <polygon points="600,150 580,180 620,180" fill={c} opacity="0.9" />
          {/* parliament base */}
          <rect x="500" y="220" width="200" height="50" fill={c} opacity="0.92" />
          <rect x="540" y="240" width="120" height="30" fill="#ff4f00" opacity="0.8" />
          {/* lake */}
          <rect x="440" y="270" width="320" height="60" fill={c} opacity="0.5" />
        </g>
        {/* VS badge */}
        <g transform="translate(400, 180)">
          <circle r="32" fill="#ff4f00" />
          <text y="8" text-anchor="middle" font-family="var(--font-display)" font-weight="800" font-size="22" fill={c}>VS</text>
        </g>
      </g>
    )}

    {feature === 'boots' && (
      <g>
        {/* coat hook */}
        <rect x="0" y="50" width="800" height="14" fill={a} />
        <g fill={c}>
          <rect x="120" y="64" width="6" height="20" />
          <rect x="320" y="64" width="6" height="20" />
          <rect x="520" y="64" width="6" height="20" />
          <rect x="700" y="64" width="6" height="20" />
        </g>
        {/* coat */}
        <g transform="translate(80, 80)">
          <path d="M40 0 L100 0 L120 30 L120 200 L20 200 L20 30 Z" fill="#ff4f00" />
          <path d="M40 0 L70 30 L100 0" fill={a} opacity="0.6" />
          <rect x="65" y="40" width="10" height="120" fill={a} opacity="0.7" />
        </g>
        {/* scarf */}
        <g transform="translate(280, 90)">
          <rect x="0" y="0" width="120" height="30" fill={c} opacity="0.85" />
          <rect x="50" y="20" width="20" height="180" fill={c} opacity="0.85" />
          <rect x="60" y="200" width="6" height="14" fill="#ff4f00" />
        </g>
        {/* boot */}
        <g transform="translate(450, 180)">
          <path d="M0 0 L60 0 L80 20 L160 20 L160 80 L0 80 Z" fill={c} opacity="0.95" />
          <line x1="20" y1="20" x2="60" y2="20" stroke={a} stroke-width="2" opacity="0.7" />
          <circle cx="20" cy="40" r="2" fill={a} opacity="0.7" />
          <circle cx="36" cy="40" r="2" fill={a} opacity="0.7" />
          <circle cx="20" cy="55" r="2" fill={a} opacity="0.7" />
          <circle cx="36" cy="55" r="2" fill={a} opacity="0.7" />
        </g>
        {/* second boot */}
        <g transform="translate(640, 200)">
          <path d="M0 0 L50 0 L65 16 L130 16 L130 60 L0 60 Z" fill={c} opacity="0.85" />
        </g>
      </g>
    )}

    {feature === 'checklist' && (
      <g>
        {/* clipboard */}
        <rect x="220" y="60" width="360" height="280" rx="6" fill={c} opacity="0.96" />
        <rect x="320" y="40" width="160" height="40" rx="6" fill={a} />
        <rect x="370" y="50" width="60" height="20" rx="3" fill="#ff4f00" />
        {/* lines */}
        {[110, 150, 190, 230, 270, 310].map((y, i) => (
          <g>
            {/* check box */}
            <rect x="250" y={y - 12} width="20" height="20" rx="3" fill="none" stroke={a} stroke-width="2" />
            {i < 4 && (
              <polyline
                points={`254,${y - 2} 260,${y + 4} 268,${y - 8}`}
                fill="none"
                stroke="#ff4f00"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            )}
            {/* line */}
            <rect x="285" y={y - 6} width="260" height="8" rx="2" fill={a} opacity={i < 4 ? 0.85 : 0.35} />
          </g>
        ))}
      </g>
    )}
  </svg>
</div>

<style>
  .post-feature {
    position: relative;
    width: 100%;
    aspect-ratio: 20 / 9;
    overflow: hidden;
    background: var(--color-light-sand);
    border: 1px solid var(--color-sand);
    border-radius: 14px;
  }
  .post-feature svg { width: 100%; height: 100%; display: block; }
</style>
