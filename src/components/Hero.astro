---
import { SITE } from '~/lib/site'

interface Props {
  tourCount: number
  rating: number
  reviewCount: number
}
const { tourCount, rating, reviewCount } = Astro.props
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-stage">
      <div class="hero-art">
        <picture>
          <source
            type="image/avif"
            media="(max-width: 540px)"
            srcset="/hobart-hero-480.avif 1x, /hobart-hero-640.avif 1.5x"
          />
          <source
            type="image/avif"
            srcset="/hobart-hero-640.avif 640w, /hobart-hero-960.avif 960w, /hobart-hero-1280.avif 1280w, /hobart-hero-1600.avif 1600w"
            sizes="(max-width: 980px) 100vw, 47vw"
          />
          <source
            type="image/webp"
            media="(max-width: 540px)"
            srcset="/hobart-hero-480.webp 1x, /hobart-hero-640.webp 1.5x"
          />
          <img
            src="/hobart-hero-640.webp"
            srcset="/hobart-hero-640.webp 640w, /hobart-hero-960.webp 960w, /hobart-hero-1280.webp 1280w, /hobart-hero-1600.webp 1600w"
            sizes="(max-width: 980px) 100vw, 47vw"
            alt="Illustrated view of Hobart's waterfront with kunanyi/Mt Wellington behind"
            width="1600"
            height="900"
            fetchpriority="high"
            decoding="async"
          />
        </picture>
        <span class="hero-stamp">
          <span class="dot dot-pulse"></span>
          {`Small-group walking food tours of ${SITE.address.locality} · since ${SITE.established}`}
        </span>
      </div>
    </div>

    <div class="hero-text">
      <span class="kicker">A Daves company · {SITE.address.locality} crew</span>
      <h1 class="hero-headline">
        <span class="hero-headline-lead">{SITE.name}</span>
        Bring your appetite.<br />
        We take care of <span class="ink-underline">the rest.</span>
      </h1>
      <p class="hero-lede">
        A small-group walking food tour of Salamanca and the Hobart waterfront —
        Tasmanian seafood, scallop pies, chocolate, oysters, donuts and ice cream
        with the bakers, fishmongers and chocolatiers themselves.
      </p>

      <div class="hero-actions">
        <a href="/tours/hobart-food-tour/" class="btn btn-primary btn-lg">Book the food tour →</a>
        <a href="/contact/?tour=private-charter" class="btn btn-outline btn-lg">Private group enquiry</a>
      </div>

      <ul class="hero-stats" aria-label="At a glance">
        <li>
          <span class="stat-value tnum">5+</span>
          <span class="stat-label">Tasting stops · 2.5 hrs</span>
        </li>
        <li>
          <span class="stat-value tnum">{rating.toFixed(1)}</span>
          <span class="stat-label">Avg. rating · {reviewCount.toLocaleString('en-AU')} reviews</span>
        </li>
        <li>
          <span class="stat-value tnum">A$0</span>
          <span class="stat-label">Booking fees · ever</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(40px, 4vw + 20px, 80px) clamp(48px, 5vw, 96px);
    background:
      linear-gradient(180deg, var(--color-canvas) 0%, var(--color-off-white) 100%);
    border-bottom: 1px solid var(--color-sand);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-stage {
    order: 2;
  }
  .hero-text { order: 1; }

  .hero-art {
    position: relative;
    border: 1px solid var(--color-sand);
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-ink);
  }
  .hero-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-stamp {
    position: absolute;
    top: 16px;
    left: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(32, 21, 21, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: var(--color-canvas);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .hero-stamp .dot {
    width: 8px; height: 8px; border-radius: 999px; background: var(--color-accent);
  }

  .hero-text { display: flex; flex-direction: column; gap: 18px; }
  .kicker { color: var(--color-warm-gray); }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 1.6rem + 4vw, 4.4rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--color-ink);
  }
  .hero-headline-lead {
    display: block;
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 0.9rem + 0.6vw, 1.5rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-accent-strong);
    margin-bottom: 10px;
  }

  .hero-lede {
    font-size: clamp(1.05rem, 0.95rem + 0.3vw, 1.25rem);
    line-height: 1.45;
    color: var(--color-charcoal);
    max-width: 50ch;
  }

  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; }

  .hero-stats {
    list-style: none;
    margin: 24px 0 0;
    padding: 18px 0 0;
    border-top: 1px solid var(--color-sand);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .hero-stats li { display: flex; flex-direction: column; gap: 4px; }
  .stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 12px;
    color: var(--color-warm-gray);
    line-height: 1.3;
  }

  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero-stage { order: 0; }
    .hero-text { order: 1; }
  }
  @media (max-width: 540px) {
    .hero-stats { grid-template-columns: 1fr 1fr; gap: 16px; }
    .hero-stats li:last-child { grid-column: 1 / -1; }
  }
</style>
