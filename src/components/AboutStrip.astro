---
import { SITE } from '~/lib/site'
---

<section class="about-strip">
  <div class="container about-grid">
    <div class="about-mosaic" aria-hidden="true">
      <div class="snap snap-1">
        <svg viewBox="0 0 200 160" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="m1" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3a2418" />
              <stop offset="100%" stop-color="#a85a2c" />
            </linearGradient>
          </defs>
          <rect width="200" height="160" fill="url(#m1)" />
          {[...Array(5)].map((_, r) => (
            <g>
              {[...Array(8)].map((__, i) => (
                <circle cx={20 + i * 22} cy={70 + r * 15} r="3" fill="#fcd28b" opacity={0.35 + r * 0.1} />
              ))}
            </g>
          ))}
          <rect x="22" y="118" width="156" height="22" rx="2" fill="rgba(255,254,251,0.92)" />
          <text x="100" y="133" text-anchor="middle" font-family="var(--font-display)" font-size="9" font-weight="700" fill="#201515" letter-spacing="2">{SITE.aboutVenues[0].name.toUpperCase()} · {SITE.aboutVenues[0].location.toUpperCase()}</text>
        </svg>
      </div>
      <div class="snap snap-2">
        <svg viewBox="0 0 200 160" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="m2" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#2a3818" />
              <stop offset="100%" stop-color="#6e8c3a" />
            </linearGradient>
          </defs>
          <rect width="200" height="160" fill="url(#m2)" />
          {[40, 90, 140].map((x, i) => (
            <g>
              <rect x={x - 14} y={60 - i * 5} width="28" height="80" rx="3" fill="#1a1812" />
              <rect x={x - 9} y={64 - i * 5} width="18" height="10" rx="1" fill="#fcd28b" opacity="0.5" />
            </g>
          ))}
          <rect x="22" y="118" width="156" height="22" rx="2" fill="rgba(255,254,251,0.92)" />
          <text x="100" y="133" text-anchor="middle" font-family="var(--font-display)" font-size="9" font-weight="700" fill="#201515" letter-spacing="2">{SITE.aboutVenues[1].name.toUpperCase()} · {SITE.aboutVenues[1].location.toUpperCase()}</text>
        </svg>
      </div>
      <div class="tape"></div>
    </div>

    <div class="about-text">
      <span class="kicker">About the {SITE.name}</span>
      <h2 class="about-headline">
        We take care of the details.<br />
        You bring <span class="editorial">your appetite.</span>
      </h2>
      <p class="about-body">
        Eighteen years ago, Daves was one Dave running a single pub tour through
        Sydney's Rocks because the official ones missed all the good stuff. The {SITE.address.locality}
        crew opened in {SITE.established} with the same idea — a small group, a local Dave, and
        the baker / fishmonger / chocolatier / ice cream maker doing the talking themselves.
      </p>
      <p class="about-body">
        We keep groups small so you can actually meet the makers, see what's coming
        out of the oven that morning, and ask whatever you want. The food tour is
        the flagship — five-plus stops between Salamanca and Victoria Dock — with
        a handful of sister Hobart tours rolling out and the same booking-fee
        policy (zero) across the network. We are all Dave. Daves is all of us.
      </p>

      <div class="awards">
        {SITE.awards.map((a) => (
          <div class="award">
            <span class="award-rank tnum">{a.rank}</span>
            <span class="award-title">{a.title}</span>
            <span class="award-sub">{a.detail}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-strip {
    padding-block: 96px;
    background: var(--color-off-white);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .about-mosaic {
    position: relative;
    aspect-ratio: 4 / 5;
  }
  .snap {
    position: absolute;
    width: 70%;
    border: 1px solid var(--color-sand);
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-canvas);
    box-shadow: 0 18px 40px -22px rgba(32, 21, 21, 0.4);
  }
  .snap-1 { top: 0; left: 0; transform: rotate(-3deg); }
  .snap-2 { bottom: 0; right: 0; transform: rotate(2.5deg); }
  .snap svg { width: 100%; aspect-ratio: 5 / 4; display: block; }
  .tape {
    position: absolute;
    top: 16%;
    left: 60%;
    width: 90px;
    height: 26px;
    background: rgba(255, 79, 0, 0.6);
    transform: rotate(18deg);
    border-radius: 2px;
  }

  .about-text { display: flex; flex-direction: column; gap: 16px; }
  .about-headline {
    font-size: clamp(1.8rem, 1.4rem + 2.4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    font-weight: 600;
  }
  .editorial { font-size: 0.95em; }
  .about-body {
    color: var(--color-charcoal);
    line-height: 1.55;
    font-size: 1.05rem;
    max-width: 56ch;
  }
  .awards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--color-sand);
  }
  .award { display: flex; flex-direction: column; gap: 4px; }
  .award-rank { font-size: 11px; color: var(--color-warm-gray); font-weight: 700; letter-spacing: 0.14em; }
  .award-title { font-size: 14px; font-weight: 600; color: var(--color-ink); line-height: 1.25; }
  .award-sub { font-size: 12px; color: var(--color-charcoal); }

  @media (max-width: 880px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-mosaic { max-width: 360px; margin-inline: auto; }
    .awards { grid-template-columns: 1fr; }
  }
</style>
