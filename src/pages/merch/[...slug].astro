---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import Base from '~/layouts/Base.astro'
import Breadcrumbs from '~/components/Breadcrumbs.astro'
import MerchGallery from '~/components/MerchGallery.astro'
import MerchCard from '~/components/MerchCard.astro'
import SectionHead from '~/components/SectionHead.astro'
import { breadcrumbSchema, fareharborMerchUrl, merchSchema } from '~/lib/schema'
import { formatPrice, SITE } from '~/lib/site'

export async function getStaticPaths() {
  const items = await getCollection('merch')
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }))
}

interface Props { item: CollectionEntry<'merch'> }
const { item } = Astro.props
const { Content } = await render(item)

const allItems = await getCollection('merch')
const others = allItems
  .filter((i) => i.id !== item.id)
  .sort((a, b) => a.data.order - b.data.order)

const url = `/merch/${item.id}/`
const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Merch', url: '/merch/' },
  { name: item.data.title, url },
])
const productLd = merchSchema(item, url)
---

<Base
  title={item.data.title}
  description={item.data.description}
  canonical={url}
  keywords={item.data.keywords}
  ogImage={item.data.ogImage ?? item.data.heroImage}
  publishedTime={item.data.publishDate}
  modifiedTime={item.data.updatedDate ?? item.data.publishDate}
  jsonLd={[breadcrumbs, productLd]}
>
  <article>
    <section class="merch-hero">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'Merch', href: '/merch/' },
            { label: item.data.title },
          ]}
        />

        <div class="hero-grid">
          <div class="gallery-col">
            <MerchGallery
              hero={{ src: item.data.heroImage, alt: item.data.heroImageAlt }}
              gallery={item.data.gallery}
            />
          </div>

          <div class="buy-col">
            {item.data.badge && <span class="pill pill-accent">{item.data.badge}</span>}
            <h1 class="hero-title">{item.data.title}</h1>
            <p class="hero-summary">{item.data.summary}</p>

            <div class="price-block">
              <span class="price-amount tnum">{formatPrice(item.data.price, item.data.currency)}</span>
              <span class="price-meta">incl. GST · shipping at checkout</span>
            </div>

            {item.data.sizes.length > 0 && (
              <div class="sizes-block">
                <span class="block-label">Available sizes</span>
                <ul class="sizes-row">
                  {item.data.sizes.map((s) => <li>{s}</li>)}
                </ul>
                <p class="sizes-note">Pick your size in the FareHarbor checkout.</p>
              </div>
            )}

            {item.data.inStock ? (
              <a
                href={fareharborMerchUrl(item.data.fareharborItem, item.data.fareharborFlow)}
                class="btn btn-primary btn-lg buy-btn fh-button"
                data-fareharbor="lightframe"
                rel="noopener"
              >
                Buy now · {formatPrice(item.data.price, item.data.currency)}
              </a>
            ) : (
              <button type="button" class="btn btn-outline btn-lg buy-btn" disabled aria-disabled="true">
                Sold out
              </button>
            )}

            <p class="checkout-fine">
              Secure checkout via FareHarbor — opens here on the page, not a new tab.
              A$10 flat domestic shipping; international by enquiry. On a tour with us?
              Your guide can hand it over on the day — mention it at checkout.
            </p>

            <div class="prose prose-tight">
              <Content />
            </div>
          </div>
        </div>
      </div>
    </section>

    {others.length > 0 && (
      <section class="section section-paper">
        <div class="container">
          <SectionHead
            kicker="More merch"
            title="The rest of the kit"
            description="A small range, slowly growing."
            actionLabel="See all merch"
            actionHref="/merch/"
          />
          <div class="other-merch">
            {others.map((m) => <MerchCard item={m} />)}
          </div>
        </div>
      </section>
    )}
  </article>

  {/*
    FareHarbor Lightframe API — auto-attaches a click handler to every
    <a> pointing at fareharbor.com and opens the URL in an overlay
    instead of a navigation. Docs:
    https://fareharbor.com/help/website/resources/lightframe-api/
    Fails open: if the script doesn't load, the buy button still works as
    a regular link to FareHarbor.
  */}
  <script is:inline src="https://fareharbor.com/embeds/api/v1/?autolightframe=yes"></script>
</Base>

<style>
  .merch-hero {
    padding-block: clamp(24px, 3vw, 64px) clamp(32px, 4vw, 80px);
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-sand);
  }
  .merch-hero .breadcrumbs { margin-bottom: 16px; }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 48px;
    margin-top: 16px;
    align-items: start;
  }
  .gallery-col { position: sticky; top: 100px; min-width: 0; }
  .buy-col { display: flex; flex-direction: column; gap: 16px; min-width: 0; }

  .hero-title {
    font-size: clamp(1.75rem, 1.2rem + 2.4vw, 3rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
    overflow-wrap: anywhere;
  }
  .hero-summary {
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.1rem);
    line-height: 1.5;
    color: var(--color-charcoal);
    max-width: 50ch;
    margin: 0;
  }

  .price-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 0;
    border-block: 1px solid var(--color-sand);
  }
  .price-amount {
    font-size: clamp(1.6rem, 1.2rem + 1.2vw, 2rem);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .price-meta { font-size: 13px; color: var(--color-warm-gray); }

  .sizes-block { display: flex; flex-direction: column; gap: 8px; }
  .block-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-warm-gray);
  }
  .sizes-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .sizes-row li {
    padding: 8px 14px;
    border: 1px solid var(--color-sand);
    border-radius: 8px;
    background: var(--color-canvas);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
  }
  .sizes-note { font-size: 12px; color: var(--color-warm-gray); }

  .buy-btn { width: 100%; }
  .checkout-fine {
    font-size: 12px;
    color: var(--color-warm-gray);
    line-height: 1.5;
    text-align: center;
  }

  .prose-tight { margin-top: 8px; padding-top: 24px; border-top: 1px solid var(--color-light-sand); }
  .prose-tight :global(img),
  .prose-tight :global(iframe),
  .prose-tight :global(video) {
    max-width: 100%;
    height: auto;
  }

  .section { padding-block: clamp(40px, 5vw, 80px); }
  .section-paper { background: var(--color-off-white); border-block: 1px solid var(--color-sand); }
  .other-merch {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(240px, 100%), 1fr));
    gap: 20px;
  }

  /* Tablet: collapse to a single column so the gallery + buy stack vertically. */
  @media (max-width: 920px) {
    .hero-grid { grid-template-columns: 1fr; gap: 28px; }
    .gallery-col { position: static; }
  }
  /* Phone: tighten paddings, drop the page-hero gutter, full-width buy button is already there. */
  @media (max-width: 540px) {
    .hero-grid { gap: 20px; margin-top: 8px; }
    .price-block { padding: 12px 0; }
    .sizes-row li { padding: 6px 12px; font-size: 13px; }
  }
</style>
