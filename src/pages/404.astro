---
import Base from '~/layouts/Base.astro'
import DavesMark from '~/components/DavesMark.astro'
import { SITE } from '~/lib/site'
---

<Base
  title="Page not found — play the snake while you're here"
  description={`The page you were looking for has rolled off into the gutter. Play the food snake or head back to ${SITE.shortName}.`}
  noindex
  hideChrome
>
  <div class="snake-stage" id="snake-stage">
    <div class="snake-topbar">
      <a href="/" class="snake-brand" aria-label={SITE.shortName}>
        <DavesMark size={28} />
      </a>
      <div class="snake-score" aria-live="polite">
        <span class="score-label">Score</span>
        <span class="score-value tnum" id="snake-score">0</span>
        <span class="score-sep">·</span>
        <span class="score-label">Best</span>
        <span class="score-value tnum" id="snake-best">0</span>
      </div>
    </div>

    <div class="snake-headline">
      <span class="kicker">404 · Page not found</span>
      <h1>This page got eaten.</h1>
      <p class="sub">Steer the snake. Eat the {SITE.address.locality} pantry. Don&apos;t bite yourself.</p>
    </div>

    <div class="snake-board-wrap">
      <canvas
        id="snake-canvas"
        class="snake-canvas"
        aria-label="Snake game board"
        role="img"
      ></canvas>

      <div class="snake-overlay" id="snake-overlay" data-state="ready">
        <div class="overlay-card">
          <div class="overlay-title" id="overlay-title">Ready to feast?</div>
          <div class="overlay-sub" id="overlay-sub">Swipe to steer · arrow keys on desktop</div>
          <button class="btn btn-primary btn-lg" id="overlay-cta" type="button">Start</button>
          <a href="/" class="overlay-back">or head back to {SITE.shortName} →</a>
        </div>
      </div>
    </div>

    <div class="snake-legend" aria-label="Food values">
      <span><span class="emoji">🍺</span> 1</span>
      <span><span class="emoji">🍇</span> 1</span>
      <span><span class="emoji">🧀</span> 1</span>
      <span><span class="emoji">🍷</span> 2</span>
      <span><span class="emoji">🍖</span> 3</span>
    </div>

    <div class="snake-footnote">
      <a href="/tours/" class="footnote-link">Browse {SITE.address.locality} tours</a>
      <span class="dot">·</span>
      <a href="/journal/" class="footnote-link">Field journal</a>
      <span class="dot">·</span>
      <a href="/" class="footnote-link">Home</a>
    </div>
  </div>
</Base>

<style>
  .snake-stage {
    min-height: 100dvh;
    background:
      radial-gradient(80% 60% at 50% 0%, var(--color-canvas) 0%, var(--color-off-white) 70%, var(--color-light-sand) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px clamp(16px, 4vw, 32px) 24px;
    gap: 16px;
    overscroll-behavior: none;
  }

  .snake-topbar {
    width: 100%;
    max-width: 560px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .snake-brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-ink);
    text-decoration: none;
  }
  .snake-score {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 6px 12px;
    background: var(--color-canvas);
    border: 1px solid var(--color-sand);
    border-radius: 999px;
    font-size: 13px;
  }
  .score-label {
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 10px;
    font-weight: 600;
  }
  .score-value {
    color: var(--color-ink);
    font-weight: 700;
    font-size: 14px;
  }
  .score-sep { color: var(--color-sand); }

  .snake-headline {
    text-align: center;
    max-width: 560px;
  }
  .snake-headline .kicker {
    display: block;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .snake-headline h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.3rem + 2.5vw, 3rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 6px;
    font-weight: 700;
  }
  .snake-headline .sub {
    color: var(--color-charcoal);
    font-size: 0.95rem;
    margin: 0;
  }

  .snake-board-wrap {
    position: relative;
    line-height: 0;
    width: min(100%, 480px);
    aspect-ratio: 1 / 1;
  }
  .snake-canvas {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-canvas);
    border: 1px solid var(--color-sand);
    border-radius: 14px;
    box-shadow: 0 24px 60px -40px rgba(32, 21, 21, 0.4);
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
  }

  .snake-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(32, 21, 21, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: opacity 180ms ease;
  }
  .snake-overlay[data-state="playing"] {
    opacity: 0;
    pointer-events: none;
  }
  .overlay-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-sand);
    border-radius: 12px;
    padding: 22px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 240px;
    max-width: 320px;
    box-shadow: 0 18px 48px -24px rgba(32, 21, 21, 0.5);
  }
  .overlay-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .overlay-sub {
    color: var(--color-warm-gray);
    font-size: 0.85rem;
  }
  .overlay-card .btn {
    margin-top: 4px;
  }
  .overlay-back {
    color: var(--color-warm-gray);
    font-size: 0.8rem;
    text-decoration: none;
    margin-top: 4px;
  }
  .overlay-back:hover { color: var(--color-accent-strong); }

  .snake-legend {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    color: var(--color-charcoal);
    font-size: 13px;
    font-weight: 600;
  }
  .snake-legend .emoji {
    font-size: 16px;
    margin-right: 2px;
    vertical-align: -2px;
  }

  .snake-footnote {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-warm-gray);
    font-size: 12px;
  }
  .snake-footnote .footnote-link {
    color: var(--color-warm-gray);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .snake-footnote .footnote-link:hover {
    color: var(--color-ink);
    border-color: var(--color-sand);
  }
  .snake-footnote .dot { opacity: 0.6; }

  @media (max-width: 540px) {
    .snake-stage { gap: 12px; padding-block: 12px 16px; }
    .snake-headline h1 { font-size: 1.7rem; }
    .snake-headline .sub { font-size: 0.85rem; }
    .snake-legend { font-size: 12px; gap: 10px; }
  }
</style>

<script>
  const COLS = 17
  const ROWS = 17
  const BASE_STEP_MS = 150
  const MIN_STEP_MS = 70
  const FOODS = [
    { emoji: '🍺', points: 1 },
    { emoji: '🍇', points: 1 },
    { emoji: '🧀', points: 1 },
    { emoji: '🍷', points: 2 },
    { emoji: '🍖', points: 3 },
  ] as const

  type Vec = { x: number; y: number }
  type Food = Vec & { emoji: string; points: number }

  const canvas = document.getElementById('snake-canvas') as HTMLCanvasElement | null
  const overlay = document.getElementById('snake-overlay') as HTMLDivElement | null
  const overlayTitle = document.getElementById('overlay-title') as HTMLDivElement | null
  const overlaySub = document.getElementById('overlay-sub') as HTMLDivElement | null
  const overlayCta = document.getElementById('overlay-cta') as HTMLButtonElement | null
  const scoreEl = document.getElementById('snake-score') as HTMLSpanElement | null
  const bestEl = document.getElementById('snake-best') as HTMLSpanElement | null

  if (canvas && overlay && overlayTitle && overlaySub && overlayCta && scoreEl && bestEl) {
    const ctx = canvas.getContext('2d')!

    let cell = 22
    let dpr = 1
    let snake: Vec[] = []
    let dir: Vec = { x: 1, y: 0 }
    let queuedDir: Vec = dir
    let food: Food = randomFood([])
    let score = 0
    let best = 0
    let state: 'ready' | 'playing' | 'over' = 'ready'
    let acc = 0
    let last = 0
    let raf = 0

    try {
      best = parseInt(localStorage.getItem('daves-snake-best') || '0', 10) || 0
    } catch {}
    bestEl.textContent = String(best)

    function sizeCanvas() {
      const cssW = canvas!.clientWidth || 320
      const cssH = canvas!.clientHeight || 320
      cell = Math.floor(Math.min(cssW, cssH) / COLS)
      dpr = Math.min(window.devicePixelRatio || 1, 2)
      canvas!.width = Math.round(cell * COLS * dpr)
      canvas!.height = Math.round(cell * ROWS * dpr)
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
      draw()
    }

    function reset() {
      const mid = Math.floor(ROWS / 2)
      snake = [
        { x: 8, y: mid },
        { x: 7, y: mid },
        { x: 6, y: mid },
      ]
      dir = { x: 1, y: 0 }
      queuedDir = dir
      food = randomFood(snake)
      score = 0
      scoreEl!.textContent = '0'
      acc = 0
      last = 0
    }

    function randomFood(occupied: Vec[]): Food {
      let x = 0
      let y = 0
      for (let i = 0; i < 200; i++) {
        x = Math.floor(Math.random() * COLS)
        y = Math.floor(Math.random() * ROWS)
        if (!occupied.some((s) => s.x === x && s.y === y)) break
      }
      const pick = FOODS[Math.floor(Math.random() * FOODS.length)]
      return { x, y, emoji: pick.emoji, points: pick.points }
    }

    function step() {
      dir = queuedDir
      const head: Vec = { x: snake[0].x + dir.x, y: snake[0].y + dir.y }
      if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) return die()
      for (let i = 0; i < snake.length; i++) {
        if (snake[i].x === head.x && snake[i].y === head.y) return die()
      }
      snake.unshift(head)
      if (head.x === food.x && head.y === food.y) {
        score += food.points
        scoreEl!.textContent = String(score)
        food = randomFood(snake)
      } else {
        snake.pop()
      }
    }

    function currentStepMs() {
      return Math.max(MIN_STEP_MS, BASE_STEP_MS - score * 3)
    }

    function loop(t: number) {
      if (state !== 'playing') return
      if (!last) last = t
      const delta = t - last
      last = t
      acc += delta
      const ms = currentStepMs()
      let safety = 4
      while (acc >= ms && state === ('playing' as typeof state) && safety-- > 0) {
        step()
        acc -= ms
      }
      draw()
      if (state === ('playing' as typeof state)) raf = requestAnimationFrame(loop)
    }

    function draw() {
      const w = cell * COLS
      const h = cell * ROWS
      ctx.clearRect(0, 0, w, h)

      // subtle grid stripes for depth
      ctx.fillStyle = 'rgba(32, 21, 21, 0.02)'
      for (let y = 0; y < ROWS; y++) {
        for (let x = (y % 2); x < COLS; x += 2) {
          ctx.fillRect(x * cell, y * cell, cell, cell)
        }
      }

      // food
      ctx.font = `${Math.round(cell * 0.78)}px "Apple Color Emoji","Segoe UI Emoji","Noto Color Emoji",sans-serif`
      ctx.textAlign = 'center'
      ctx.textBaseline = 'middle'
      ctx.fillText(food.emoji, food.x * cell + cell / 2, food.y * cell + cell / 2 + 1)

      // snake — body
      const pad = Math.max(1, Math.round(cell * 0.08))
      for (let i = snake.length - 1; i >= 0; i--) {
        const seg = snake[i]
        const head = i === 0
        ctx.fillStyle = head ? '#cc4f1a' : '#e8743a'
        roundRect(
          ctx,
          seg.x * cell + pad,
          seg.y * cell + pad,
          cell - pad * 2,
          cell - pad * 2,
          Math.round(cell * 0.28),
        )
        ctx.fill()
      }

      // eyes on head
      if (snake.length) {
        const head = snake[0]
        const cx = head.x * cell + cell / 2
        const cy = head.y * cell + cell / 2
        const r = Math.max(1.5, cell * 0.08)
        const off = cell * 0.18
        const ex = dir.x !== 0 ? dir.x * cell * 0.18 : 0
        const ey = dir.y !== 0 ? dir.y * cell * 0.18 : 0
        const perpx = dir.x !== 0 ? 0 : off
        const perpy = dir.y !== 0 ? 0 : off
        const apx = dir.y !== 0 ? off : 0
        const apy = dir.x !== 0 ? off : 0
        ctx.fillStyle = '#ffffff'
        ctx.beginPath()
        ctx.arc(cx + ex + apx, cy + ey + perpy, r, 0, Math.PI * 2)
        ctx.arc(cx + ex - apx, cy + ey - perpy, r, 0, Math.PI * 2)
        ctx.fill()
        ctx.fillStyle = '#201515'
        ctx.beginPath()
        ctx.arc(cx + ex + apx, cy + ey + perpy, r * 0.55, 0, Math.PI * 2)
        ctx.arc(cx + ex - apx, cy + ey - perpy, r * 0.55, 0, Math.PI * 2)
        ctx.fill()
      }
    }

    function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
      const rad = Math.min(r, w / 2, h / 2)
      c.beginPath()
      c.moveTo(x + rad, y)
      c.arcTo(x + w, y, x + w, y + h, rad)
      c.arcTo(x + w, y + h, x, y + h, rad)
      c.arcTo(x, y + h, x, y, rad)
      c.arcTo(x, y, x + w, y, rad)
      c.closePath()
    }

    function start() {
      reset()
      state = 'playing'
      overlay!.dataset.state = 'playing'
      cancelAnimationFrame(raf)
      raf = requestAnimationFrame(loop)
    }

    function die() {
      state = 'over'
      overlay!.dataset.state = 'over'
      overlayTitle!.textContent = 'Eaten by your own tail.'
      overlaySub!.textContent = `Score ${score}${score > best ? ' · new best!' : ''}`
      overlayCta!.textContent = 'Play again'
      if (score > best) {
        best = score
        bestEl!.textContent = String(best)
        try {
          localStorage.setItem('daves-snake-best', String(best))
        } catch {}
      }
      cancelAnimationFrame(raf)
    }

    function setQueued(nx: number, ny: number) {
      // disallow reversing into the body
      if (snake.length > 1 && nx === -dir.x && ny === -dir.y) return
      queuedDir = { x: nx, y: ny }
    }

    // Keyboard
    window.addEventListener('keydown', (e) => {
      const k = e.key
      const map: Record<string, [number, number]> = {
        ArrowUp: [0, -1], w: [0, -1], W: [0, -1],
        ArrowDown: [0, 1], s: [0, 1], S: [0, 1],
        ArrowLeft: [-1, 0], a: [-1, 0], A: [-1, 0],
        ArrowRight: [1, 0], d: [1, 0], D: [1, 0],
      }
      if (map[k]) {
        e.preventDefault()
        if (state === 'ready') {
          start()
        }
        if (state === 'playing') {
          setQueued(map[k][0], map[k][1])
        }
        return
      }
      if ((k === ' ' || k === 'Enter') && state !== 'playing') {
        e.preventDefault()
        start()
      }
    })

    // Touch / swipe
    let tx = 0
    let ty = 0
    let tracking = false
    canvas.addEventListener(
      'touchstart',
      (e) => {
        if (e.touches.length !== 1) return
        tx = e.touches[0].clientX
        ty = e.touches[0].clientY
        tracking = true
      },
      { passive: true },
    )
    canvas.addEventListener(
      'touchmove',
      (e) => {
        if (!tracking || state !== 'playing') return
        const dx = e.touches[0].clientX - tx
        const dy = e.touches[0].clientY - ty
        const ax = Math.abs(dx)
        const ay = Math.abs(dy)
        const TH = 22
        if (Math.max(ax, ay) < TH) return
        if (ax > ay) {
          setQueued(dx > 0 ? 1 : -1, 0)
        } else {
          setQueued(0, dy > 0 ? 1 : -1)
        }
        tx = e.touches[0].clientX
        ty = e.touches[0].clientY
      },
      { passive: true },
    )
    canvas.addEventListener(
      'touchend',
      () => {
        tracking = false
      },
      { passive: true },
    )
    canvas.addEventListener('click', () => {
      if (state === 'ready' || state === 'over') start()
    })

    overlayCta.addEventListener('click', (e) => {
      e.preventDefault()
      start()
    })

    window.addEventListener('resize', sizeCanvas)
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && state === 'playing') {
        state = 'over'
        overlay!.dataset.state = 'ready'
        overlayTitle!.textContent = 'Paused'
        overlaySub!.textContent = 'Tap to resume'
        overlayCta!.textContent = 'Resume'
      }
    })

    sizeCanvas()
    reset()
    draw()
  }
</script>
