---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import Base from '~/layouts/Base.astro'
import Breadcrumbs from '~/components/Breadcrumbs.astro'
import JournalCard from '~/components/JournalCard.astro'
import PostFeature from '~/components/PostFeature.astro'
import ClosingCTA from '~/components/ClosingCTA.astro'
import { articleSchema, breadcrumbSchema } from '~/lib/schema'
import { SITE, formatDate } from '~/lib/site'

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft)
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

interface Props { post: CollectionEntry<'posts'> }
const { post } = Astro.props
const { Content } = await render(post)

const allPosts = await getCollection('posts', ({ data }) => !data.draft)
const related = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2)

const url = `/journal/${post.id}/`
const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Field journal', url: '/journal/' },
  { name: post.data.title, url },
])
const article = articleSchema(post, url)
---

<Base
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.description}
  canonical={url}
  ogType="article"
  keywords={post.data.keywords}
  publishedTime={post.data.publishDate}
  modifiedTime={post.data.updatedDate ?? post.data.publishDate}
  jsonLd={[breadcrumbs, article]}
>
  <article>
    <header class="post-hero">
      <div class="container container-prose">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'Journal', href: '/journal/' },
            { label: post.data.title },
          ]}
        />

        <div class="post-meta-row">
          <span class="kicker post-kicker">{post.data.kicker}</span>
          <span class="post-meta-dot">·</span>
          <span>{post.data.city}</span>
          <span class="post-meta-dot">·</span>
          <span>{post.data.readingTime} read</span>
        </div>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-lede">{post.data.description}</p>

        <div class="post-byline">
          <div class="byline-stack">
            <span class="byline-name">{post.data.author}</span>
            <time class="byline-date" datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
          </div>
        </div>
      </div>
    </header>

    <div class="container container-prose post-feature-wrap">
      <PostFeature feature={post.data.featureKey} swatch={post.data.featureSwatch} />
    </div>

    <div class="post-body">
      <div class="container container-prose">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>

    {related.length > 0 && (
      <section class="related section">
        <div class="container container-prose">
          <h2 class="related-title">Keep reading</h2>
          <div class="related-list">
            {related.map((p, i) => <JournalCard post={p} index={i} />)}
          </div>
        </div>
      </section>
    )}
  </article>

  <ClosingCTA
    title="Talk it over with the people who wrote it."
    description={`The journal is a side project of walking the food tour every week. If you want a proper conversation about ${SITE.address.locality} eating, come for the morning.`}
  />
</Base>

<style>
  .post-hero {
    padding-block: clamp(48px, 4vw + 32px, 80px) clamp(24px, 3vw, 40px);
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-sand);
  }
  .post-hero .breadcrumbs { margin-bottom: 24px; }
  .post-meta-row {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: 18px;
  }
  .post-kicker { font-size: 11px; color: var(--color-accent-strong); }
  .post-meta-dot { color: var(--color-sand); }

  .post-title {
    font-size: clamp(2.2rem, 1.5rem + 3vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    font-weight: 700;
    margin-bottom: 16px;
  }
  .post-lede {
    font-family: var(--font-editorial);
    font-style: italic;
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.45rem);
    color: var(--color-charcoal);
    line-height: 1.45;
    max-width: 56ch;
  }
  .post-byline {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-sand);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .byline-stack { display: flex; flex-direction: column; gap: 2px; }
  .byline-name { font-size: 14px; font-weight: 700; color: var(--color-ink); }
  .byline-date { font-size: 13px; color: var(--color-warm-gray); }

  .post-feature-wrap {
    padding-top: clamp(28px, 3vw, 40px);
    padding-bottom: clamp(8px, 1.2vw, 16px);
  }

  .post-body { padding-block: clamp(40px, 4vw, 64px); }

  .related { background: var(--color-off-white); border-top: 1px solid var(--color-sand); }
  .related-title {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .related-list { display: flex; flex-direction: column; }
  .section { padding-block: clamp(48px, 5vw, 80px); }
</style>
